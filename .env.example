# Required for this workflow.
#
# 1. Copy this Gumloop pipeline into your own workspace:
#    https://www.gumloop.com/pipeline?workbook_id=3Pku5WWmdYaZ4nHUxjntJP
# 2. Copy the webhook URL from your copied pipeline
# 3. Run ./scripts/parse-gumloop-webhook.sh '<gumloop-webhook-url>'
# 4. Paste the extracted values below or export them in your shell
# 5. Run ./scripts/check-setup.sh before your first sourcing run
#
# Do not commit real credentials.
GUMLOOP_API_KEY=
GUMLOOP_USER_ID=
GUMLOOP_SAVED_ITEM_ID=
